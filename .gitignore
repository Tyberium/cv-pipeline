# raw_history.json is the ENCRYPTED file - that one IS committed
# raw_history_plain.json is the plaintext source - this must never be committed
raw_history_plain.json

# Plaintext headshot — only photo.enc is committed (same CV_SECRET as raw_history)
photo.png

